<Window x:Class="Dt1520.Authenticator.DesktopWpfTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DT-1520 Desktop WPF Test"
        Width="1040"
        Height="720"
        MinWidth="860"
        MinHeight="620">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="Load JSON" Command="{Binding LoadSettingsCommand}" />
                    <Button Content="Save JSON" Command="{Binding SaveSettingsCommand}" />
                </StackPanel>
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Text="DT-1520 Desktop WPF Test" />
            </DockPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="360" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" MinWidth="360" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <GroupBox Header="Reference backend">
                        <StackPanel>
                            <TextBlock Text="Backend base URL" />
                            <TextBox Text="{Binding ReferenceBackendBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="DT-1520 live config, demo storage only">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DT-1520 base URL" />
                                <TextBox Text="{Binding Dt1520BaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Tenant ID" />
                                <TextBox Text="{Binding TenantId, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Application Client ID" />
                                <TextBox Text="{Binding ApplicationClientId, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Scope" />
                                <TextBox Text="{Binding Scope, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Client ID" />
                                <TextBox Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Client secret" />
                                <TextBox Text="{Binding ClientSecret, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Callback signing secret" />
                                <TextBox Text="{Binding CallbackSigningSecret, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Callback URL" />
                                <TextBox Text="{Binding CallbackUrl, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <GroupBox Header="Protected operation">
                        <StackPanel>
                            <TextBlock Text="External user ID" />
                            <TextBox Text="{Binding ExternalUserId, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Display name" />
                            <TextBox Text="{Binding OperationDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                            <WrapPanel>
                                <Button Content="Start approval" Command="{Binding StartApprovalCommand}" />
                                <Button Content="Poll status" Command="{Binding PollStatusCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Online TOTP fallback">
                        <StackPanel>
                            <TextBlock Text="TOTP code" />
                            <TextBox MaxLength="12"
                                     Text="{Binding TotpCode, UpdateSourceTrigger=PropertyChanged}" />
                            <WrapPanel>
                                <Button Content="Submit TOTP" Command="{Binding SubmitTotpCommand}" />
                                <Button Content="Clear" Command="{Binding ClearTotpCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Status">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="Session" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SessionId}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="Polling path" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PollingPath}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Text="Status" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ApprovalStatus}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="SemiBold" Text="Committed" />
                                <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding IsCommitted, Mode=OneWay}" IsEnabled="False" />
                                <TextBlock Grid.Row="4" Grid.Column="0" FontWeight="SemiBold" Text="Busy" />
                                <CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding IsBusy, Mode=OneWay}" IsEnabled="False" />
                            </Grid>
                            <TextBlock Margin="0,8,0,4" FontWeight="SemiBold" Text="Message" />
                            <TextBox MinHeight="48"
                                     IsReadOnly="True"
                                     Text="{Binding LastMessage, Mode=OneWay}"
                                     TextWrapping="Wrap" />
                            <TextBlock Margin="0,4,0,4" FontWeight="SemiBold" Text="Latency timestamps" />
                            <TextBox MinHeight="120"
                                     IsReadOnly="True"
                                     Text="{Binding LatencySummary, Mode=OneWay}"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
