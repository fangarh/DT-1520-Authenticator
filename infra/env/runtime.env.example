# Copy this file outside git-tracked paths before first install, for example:
#   cp infra/env/runtime.env.example /opt/otpauth/runtime.env
# Then use:
#   docker compose --env-file /opt/otpauth/runtime.env -f infra/docker-compose.yml up -d

OTPAUTH_POSTGRES_DB=otpauth
OTPAUTH_POSTGRES_USER=otpauth
OTPAUTH_POSTGRES_PASSWORD=replace-with-strong-postgres-password

OTPAUTH_REDIS_PASSWORD=replace-with-strong-redis-password

ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=otpauth;Username=otpauth;Password=replace-with-strong-postgres-password;SSL Mode=Disable

BootstrapOAuth__CurrentSigningKeyId=bootstrap-current
BootstrapOAuth__CurrentSigningKey=replace-with-base64-or-long-random-signing-key

TotpProtection__CurrentKeyVersion=1
TotpProtection__CurrentKey=replace-with-base64-32-byte-key

# Absolute host paths recommended for production hosts.
OTPAUTH_TLS_CERT_PATH=/opt/otpauth/tls/tls.crt
OTPAUTH_TLS_KEY_PATH=/opt/otpauth/tls/tls.key

OTPAUTH_ADMIN_HTTPS_PORT=8443
