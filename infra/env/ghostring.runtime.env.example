# Copy this file outside git-tracked paths before first deploy, for example:
#   sudo install -d -m 700 /opt/dt-1520-authenticator
#   sudo cp infra/env/ghostring.runtime.env.example /opt/dt-1520-authenticator/runtime.env
# Then use:
#   docker compose --env-file /opt/dt-1520-authenticator/runtime.env -f infra/docker-compose.ghostring.yml up -d redis api worker admin

# Existing PostgreSQL on the host or a separate managed instance.
ConnectionStrings__Postgres=Host=127.0.0.1;Port=5432;Database=dt-auth;Username=dt_auth_app;Password=replace-with-strong-db-password;SSL Mode=Disable

# Dedicated Redis runtime for DT-1520 on this server.
OTPAUTH_REDIS_PASSWORD=replace-with-strong-redis-password

# Required runtime signing and protection material.
BootstrapOAuth__CurrentSigningKeyId=bootstrap-current
BootstrapOAuth__CurrentSigningKey=replace-with-long-random-signing-key
TotpProtection__CurrentKeyVersion=1
TotpProtection__CurrentKey=replace-with-base64-32-byte-key
ChallengeCallbacks__SigningKey=replace-with-long-random-callback-signing-key
Webhooks__SigningKey=replace-with-long-random-webhook-signing-key

# Start with logging during infrastructure bring-up. Switch to fcm only after runtime is stable.
PushDelivery__Provider=logging

# Uncomment only when switching to FCM.
# PushDelivery__Provider=fcm
# PushDelivery__Fcm__ProjectId=replace-with-google-project-id
# PushDelivery__Fcm__ServiceAccountFilePath=/opt/dt-1520-authenticator/secrets/fcm-service-account.json
# PushDelivery__Fcm__ServiceAccountJsonBase64=

# Internal admin HTTPS certificate used between host nginx and the admin container.
# Prefer reusing the same chain as admin.ghostring.ru or another certificate trusted by the host OS.
OTPAUTH_TLS_CERT_PATH=/opt/dt-1520-authenticator/tls/admin-internal.crt
OTPAUTH_TLS_KEY_PATH=/opt/dt-1520-authenticator/tls/admin-internal.key

# Loopback-only HTTPS port for the admin container. Host nginx terminates public TLS on 443.
OTPAUTH_GHOSTRING_ADMIN_HTTPS_PORT=18443
