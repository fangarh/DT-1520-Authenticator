{
  "WorkerDiagnostics": {
    "HeartbeatIntervalSeconds": 30,
    "DependencyProbeTimeoutSeconds": 5
  },
  "WorkerJobs": {
    "SecurityDataCleanup": {
      "Enabled": true,
      "IntervalSeconds": 300
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
