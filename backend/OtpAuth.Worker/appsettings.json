{
  "WorkerDiagnostics": {
    "HeartbeatIntervalSeconds": 30,
    "DependencyProbeTimeoutSeconds": 5
  },
  "WorkerJobs": {
    "SecurityDataCleanup": {
      "Enabled": true,
      "IntervalSeconds": 300
    },
    "PushChallengeDelivery": {
      "Enabled": true,
      "IntervalSeconds": 15,
      "BatchSize": 20,
      "LeaseSeconds": 60,
      "RetryDelaySeconds": 30,
      "MaxAttempts": 5
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
