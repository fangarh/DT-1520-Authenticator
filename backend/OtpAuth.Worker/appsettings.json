{
  "WorkerDiagnostics": {
    "HeartbeatIntervalSeconds": 30,
    "DependencyProbeTimeoutSeconds": 5
  },
  "WorkerJobs": {
    "SecurityDataCleanup": {
      "Enabled": true,
      "IntervalSeconds": 300
    },
    "ChallengeCallbackDelivery": {
      "Enabled": true,
      "IntervalSeconds": 15,
      "BatchSize": 20,
      "LeaseSeconds": 60,
      "RetryDelaySeconds": 30,
      "MaxAttempts": 5
    },
    "PushChallengeDelivery": {
      "Enabled": true,
      "IntervalSeconds": 15,
      "BatchSize": 20,
      "LeaseSeconds": 60,
      "RetryDelaySeconds": 30,
      "MaxAttempts": 5
    },
    "WebhookEventDelivery": {
      "Enabled": true,
      "IntervalSeconds": 15,
      "BatchSize": 20,
      "LeaseSeconds": 60,
      "RetryDelaySeconds": 30,
      "MaxAttempts": 5
    }
  },
  "ChallengeCallbacks": {
    "TimeoutSeconds": 5,
    "UserAgent": "OtpAuth-Callbacks/1.0"
  },
  "Webhooks": {
    "TimeoutSeconds": 5,
    "UserAgent": "OtpAuth-Webhooks/1.0"
  },
  "PushDelivery": {
    "Provider": "logging",
    "Fcm": {
      "TimeoutSeconds": 5,
      "UserAgent": "OtpAuth-Push-FCM/1.0"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
